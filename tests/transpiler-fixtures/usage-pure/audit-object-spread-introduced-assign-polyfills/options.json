{
  "plugins": [
    [
      "@core-js",
      {
        "method": "usage-pure",
        "version": "4.0",
        "targets": {
          "ie": 11
        }
      }
    ],
    "@babel/plugin-transform-object-rest-spread"
  ],
  "assumptions": {
    "setSpreadProperties": true
  },
  "sourceType": "module"
}

{
  "plugins": [
    [
      "@core-js",
      {
        "method": "usage-pure",
        "version": "4.0",
        "targets": {
          "ie": 11
        }
      }
    ],
    "@babel/plugin-transform-arrow-functions",
    "@babel/plugin-transform-destructuring",
    "@babel/plugin-transform-parameters"
  ],
  "sourceType": "module"
}
